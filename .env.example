# Iptables-Secure - Environment Configuration Template

# ------------------------------------------------------------------------------
# SECURITY SETTINGS
# ------------------------------------------------------------------------------

# Allowed IP addresses for SSH access (comma separated)
# Example: 192.168.1.100, 10.0.0.50
ALLOWED_SSH_IPS=127.0.0.1

# HTTP port limit (connections per IP)
# Default: 20
HTTP_CONNLIMIT=20

# ------------------------------------------------------------------------------
# SYSTEM SETTINGS
# ------------------------------------------------------------------------------

# Path to the log file
# Default: iptables_rules.log
LOG_FILE=iptables_rules.log

# Path to persistent rules (Debian/Ubuntu)
# Default: /etc/iptables/rules.v4
RULES_V4_PATH=/etc/iptables/rules.v4
